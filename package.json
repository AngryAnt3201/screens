{
  "name": "screen-visualiser",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A native desktop canvas of every screen in your web project — with a real WebView, DevTools, multi-account session isolation, and a CLI for code-driven management.",
  "bin": {
    "screens": "./bin/screens.mjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "tauri": "tauri",
    "app:dev": "tauri dev",
    "app:build": "tauri build",
    "screens": "node ./bin/screens.mjs",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@xyflow/react": "^12.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
